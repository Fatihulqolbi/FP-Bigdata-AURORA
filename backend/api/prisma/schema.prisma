generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mongodb"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

enum Role {
  ADMIN
  ADMIN_TPS
  BANK_SAMPAH
  INDUSTRI
  WARGA
  UMKM
  DRIVER
}

enum AdminLevel {
  SUPER_ADMIN
  ADMIN_VERIFICATION
  ADMIN_OPERATIONAL
  ADMIN_REGIONAL
}

enum AccountStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  REJECTED
}

enum ListingType {
  MATERIAL
  PRODUCT
}

enum ListingStatus {
  ACTIVE
  SOLD_OUT
  EXPIRED
  DRAFT
}

enum DemandStatus {
  OPEN
  PARTIALLY_FULFILLED
  FULFILLED
  CANCELLED
}

enum OrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  AWAITING_PAYMENT
  PAID
  READY_FOR_PICKUP
  READY_FOR_DELIVERY
  IN_TRANSIT
  DELIVERED
  COMPLETED
  CANCELLED
  DISPUTE
  RESOLVED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_BUYER
  RESOLVED_SELLER
  CLOSED
}

enum FulfillmentOption {
  PICKUP
  DELIVERY
  BOTH
}

enum LogisticsOption {
  PICKUP
  DELIVERY
}

enum TruckType {
  COMPACTOR_10
  COMPACTOR_6_5
  DUMP_TRUCK
  ARMROLL_14
  ARMROLL_8
  ARMROLL_6
  PICK_UP
}

enum FacilityType {
  TPS
  TPS3R
  RUMAH_KOMPOS
  PLTSA
  SUPERDEPO
  TRANSFER_STATION
}

enum PengangkutanType {
  ARMROLL
  COMPACTOR
}

model User {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  email         String        @unique
  passwordHash  String
  role          Role
  adminLevel    AdminLevel?     // only for ADMIN role
  status        AccountStatus @default(PENDING_VERIFICATION)
  verifiedBy    String?       @db.ObjectId
  name          String
  address       String?
  kecamatan     String?
  lat           Float?
  lng           Float?
  contact       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Regional admin scope
  assignedKecamatans String[]   @default([])

  // Seller profile
  verificationDoc String?
  sellerRating    Float        @default(0)

  // Industry profile
  industryDoc   String?

  // Forgot password
  resetToken        String?
  resetTokenExpires DateTime?

  // Documents upload (bypass for now, form available)
  uploadedDocuments String[]  @default([])

  listings      Listing[]     @relation("SellerListings")
  demands       Demand[]      @relation("BuyerDemands")
  orders        Order[]       @relation("BuyerOrders")
  reviews       Review[]      @relation("UserReviews")

  @@map("users")
}

model MaterialCategory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  description String?
  unit        String   @default("kg")
  minPrice    Float
  maxPrice    Float
  gradeOptions String[] @default([])
  isProduct   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  listings    Listing[] @relation("CategoryListings")
  demands     Demand[]  @relation("CategoryDemands")

  @@map("material_categories")
}

model Listing {
  id                 String            @id @default(auto()) @map("_id") @db.ObjectId
  sellerId           String            @db.ObjectId
  seller             User              @relation("SellerListings", fields: [sellerId], references: [id])
  type               ListingType       @default(MATERIAL)
  categoryId         String            @db.ObjectId
  category           MaterialCategory  @relation("CategoryListings", fields: [categoryId], references: [id])
  title              String
  description        String?
  quantity           Float
  pricePerKg         Float
  moq                Float             @default(1)
  fulfillmentOptions FulfillmentOption @default(BOTH)
  lat                Float
  lng                Float
  status             ListingStatus     @default(ACTIVE)
  grade              String?
  expiresAt          DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  orderItems         OrderItem[]       @relation("ListingOrderItems")

  @@map("listings")
}

model Demand {
  id                String            @id @default(auto()) @map("_id") @db.ObjectId
  buyerId           String            @db.ObjectId
  buyer             User              @relation("BuyerDemands", fields: [buyerId], references: [id])
  categoryId        String            @db.ObjectId
  category          MaterialCategory  @relation("CategoryDemands", fields: [categoryId], references: [id])
  quantityNeeded    Float
  maxPrice          Float
  preferredDistance Float            @default(50)
  lat               Float?
  lng               Float?
  status            DemandStatus      @default(OPEN)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  matchSuggestions  MatchSuggestion[] @relation("DemandMatches")
  orders            Order[]           @relation("DemandOrders")

  @@map("demands")
}

model MatchSuggestion {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  demandId        String   @db.ObjectId
  demand          Demand   @relation("DemandMatches", fields: [demandId], references: [id])
  candidateData   Json
  totalQuantity   Float
  totalCost       Float
  distanceKm      Float
  score           Float
  status          String   @default("SUGGESTED")
  createdAt       DateTime @default(now())

  @@map("match_suggestions")
}

model Order {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  buyerId         String          @db.ObjectId
  buyer           User            @relation("BuyerOrders", fields: [buyerId], references: [id])
  demandId        String?         @db.ObjectId
  demand          Demand?         @relation("DemandOrders", fields: [demandId], references: [id])
  items           OrderItem[]
  status          OrderStatus     @default(DRAFT)
  logisticsOption LogisticsOption?
  totalQuantity   Float           @default(0)
  totalAmount     Float           @default(0)
  notes           String?
  paymentProof    String?
  dispute         Dispute?        @relation("OrderDispute")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("orders")
}

model OrderItem {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  orderId     String        @db.ObjectId
  order       Order         @relation(fields: [orderId], references: [id])
  listingId   String        @db.ObjectId
  listing     Listing       @relation("ListingOrderItems", fields: [listingId], references: [id])
  sellerId    String        @db.ObjectId
  quantity    Float
  pricePerKg  Float
  subtotal    Float
  status      OrderStatus   @default(PENDING_APPROVAL)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("order_items")
}

model Dispute {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  orderId     String        @db.ObjectId @unique
  order       Order         @relation("OrderDispute", fields: [orderId], references: [id])
  filedBy     String        @db.ObjectId
  reason      String
  description String?
  evidence    String[]      @default([])
  status      DisputeStatus @default(OPEN)
  resolution  String?
  resolvedBy  String?       @db.ObjectId
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("disputes")
}

model Review {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId     String   @db.ObjectId
  reviewerId  String   @db.ObjectId
  reviewer    User     @relation("UserReviews", fields: [reviewerId], references: [id])
  targetId    String   @db.ObjectId
  rating      Float
  comment     String?
  createdAt   DateTime @default(now())

  @@map("reviews")
}

model AuditLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String?  @db.ObjectId
  action      String
  entity      String
  entityId    String?
  detail      Json?
  createdAt   DateTime @default(now())

  @@map("audit_logs")
}

model Tps {
  id                      String   @id @default(auto()) @map("_id") @db.ObjectId
  code                    String   @unique
  name                    String
  kecamatan               String
  kelurahan               String?
  lat                     Float
  lng                     Float
  capacityKg              Float    @default(0)
  fillThreshold           Float    @default(0.9)
  currentVolume           Float    @default(0)
  status                  String   @default("AKTIF")
  type                    String   @default("TPS_BIASA")
  schedule                Json     @default("[]")
  needsReview             Boolean  @default(true)
  verifiedBy              String?  @db.ObjectId
  verifiedAt              DateTime?
  source                  String   @default("PDF")
  rawAddress              String?
  confidence              Float    @default(0)
  images                  String[] @default([])
  adminId                 String?  @db.ObjectId
  
  volMasukM3              Float?
  volDikelolaM3           Float?
  volDiangkutM3           Float?
  estimasiBeratKg         Float?
  isJalanProtokol         Boolean  @default(false)
  klasifikasiPengangkutan String?
  jenisFasilitas          String?
  
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("tps")
}

model Truck {
  id                      String   @id @default(auto()) @map("_id") @db.ObjectId
  code                    String   @unique
  name                    String
  type                    String
  capacityKg              Float
  currentLoadKg           Float    @default(0)
  status                  String   @default("AVAILABLE")
  lat                     Float?
  lng                     Float?
  heading                 Float?
  driverId                String?  @db.ObjectId
  assignedTpsId           String?  @db.ObjectId
  destinationLat          Float?
  destinationLng          Float?
  facilityId              String?  @db.ObjectId
  route                   Json?
  routeProgress           Float    @default(0)
  routeDistance           Float?
  routeDuration           Float?
  routeWaypoints          Json?
  routeQueue              Json?
  routeLegIndex           Int      @default(0)
  backupCode              String?
  backupCodeGeneratedAt   DateTime?
  loadingDurationSeconds  Int?
  loadingStartedAt        DateTime?
  unloadingDurationSeconds Int?
  volumeM3                Float    @default(0)
  canCompact              Boolean  @default(false)
  isJalanProtokol         Boolean  @default(false)
  maxTpsPerRoute          Int      @default(4)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("trucks")
}

model SortingHub {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  code            String   @unique
  name            String
  type            String
  kecamatan       String?
  lat             Float
  lng             Float
  capacityKg      Float
  currentLoadKg   Float    @default(0)
  dailyCapacityKg Float?
  dailyIntakeKg   Float    @default(0)
  lastIntakeReset DateTime @default(now())
  acceptsTypes    String[] @default([])
  operationalCostPerKg Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("sorting_hubs")
}

model ScheduledEvent {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId          String   @unique
  eventName        String
  month            Int?
  day              Int?
  dayOfWeek        Int?
  targetKecamatan  String
  targetKelurahan  String?
  volumeMultiplier Float
  locations        String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("scheduled_events")
}

model WasteRiskIndex {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  regionId          String
  regionName        String
  timestamp         DateTime @default(now())
  avgFillLevel      Float
  volumeTrend       Float
  populationDensity Float
  wriValue          Float
  alpha             Float    @default(0.4)
  beta              Float    @default(0.35)
  gamma             Float    @default(0.25)
  alertStatus       String
  recommendedAction String?
  createdAt         DateTime @default(now())

  @@index([regionId, timestamp])
  @@map("waste_risk_index")
}

model TpsOverloadPrediction {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  tpsId                String   @db.ObjectId
  tpsCode              String
  tpsName              String
  timestamp            DateTime @default(now())
  currentVolumeKg      Float
  capacityKg           Float
  fillLevel            Float
  inflowRateKgPerHour  Float
  outflowRateKgPerHour Float
  netRateKgPerHour     Float
  lambda               Float
  overloadProb24h      Float
  overloadProb48h      Float
  overloadProb72h      Float
  estimatedHoursToFull Float?
  estimatedFullAt      DateTime?
  riskLevel            String
  createdAt            DateTime @default(now())

  @@index([tpsId, timestamp])
  @@map("tps_overload_predictions")
}

model FacilityUtilization {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  facilityId      String   @db.ObjectId
  facilityCode    String
  facilityName    String
  timestamp       DateTime @default(now())
  processed24hKg  Float
  inTransitKg     Float
  dailyCapacityKg Float
  utilizationRate Float
  status          String
  canAcceptMore   Boolean
  trucksEnRoute   Int
  createdAt       DateTime @default(now())

  @@index([facilityId, timestamp])
  @@map("facility_utilization")
}

model RegionalPopulationDensity {
  id                        String   @id @default(auto()) @map("_id") @db.ObjectId
  regionId                  String   @unique
  regionName                String
  kecamatan                 String
  population                Int
  areaKm2                   Float
  densityPerKm2             Float
  wasteGenKgPerCapitaPerDay Float    @default(0.7)
  densityMultiplier         Float
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@map("regional_population_density")
}

model CostOptimizationBaseline {
  id                       String   @id @default(auto()) @map("_id") @db.ObjectId
  periodStart              DateTime
  periodEnd                DateTime
  staticTotalDistanceKm    Float
  staticTotalFuelL         Float
  staticTotalCostRp        Float
  staticAvgKmPerTon        Float
  optimizedTotalDistanceKm Float
  optimizedTotalFuelL      Float
  optimizedTotalCostRp     Float
  optimizedAvgKmPerTon     Float
  distanceSavedKm          Float
  fuelSavedL               Float
  costSavedRp              Float
  efficiencyGainPct        Float
  testGroupSize            Int
  controlGroupSize         Int
  statisticalSignificance  Float
  createdAt                DateTime @default(now())

  @@map("cost_optimization_baseline")
}
