# Database (MongoDB via Prisma)
DATABASE_URL="mongodb://localhost:27017/aurora_marketplace"

# JWT
JWT_SECRET="change-me-to-a-random-string"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development

# Price range defaults (per kg, IDR)
DEFAULT_MIN_PRICE=500
DEFAULT_MAX_PRICE=100000

# Matching engine
MAX_DISTANCE_KM=50
INSTANT_ORDER_THRESHOLD=0.90

# Big Data pipeline
KAFKA_BROKERS="localhost:9092"
ANALYTICS_ENGINE_URL="http://localhost:4001"

# M4: Fleet routing
# OSRM routing engine URL:
#   Public demo (default, free, has rate limits): https://router.project-osrm.org
#   Local Docker (offline, fast, no rate limits):  http://localhost:5000
OSRM_BASE_URL="https://router.project-osrm.org"

# M4: Traffic (TomTom Flow Segment API)
# Get free key at https://developer.tomtom.com (2,500 req/day free tier)
TOMTOM_API_KEY=""
