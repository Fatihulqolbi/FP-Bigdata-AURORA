# Database (MongoDB via Prisma)
DATABASE_URL="mongodb://localhost:27017/aurora_marketplace"

# JWT
JWT_SECRET="change-me-to-a-random-string"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development

# Price range defaults (per kg, IDR)
DEFAULT_MIN_PRICE=500
DEFAULT_MAX_PRICE=100000

# Matching engine
MAX_DISTANCE_KM=50
INSTANT_ORDER_THRESHOLD=0.90
